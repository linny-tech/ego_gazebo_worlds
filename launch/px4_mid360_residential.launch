<?xml version="1.0"?>
<launch>
  <arg name="world" default="$(find ego_gazebo_worlds)/worlds/ego_residential_50x50x10.world"/>
  <arg name="sdf" default="$(find mavlink_sitl_gazebo)/models/iris_mid360/iris_mid360.sdf"/>
  <arg name="gui" default="true"/>

  <!-- West-edge community entrance; the center lane stays clear to the east goal. -->
  <arg name="x" default="-22.0"/>
  <arg name="y" default="0.0"/>
  <arg name="z" default="0.2"/>

  <include file="$(find px4)/launch/mavros_posix_sitl.launch">
    <arg name="vehicle" value="iris"/>
    <arg name="world" value="$(arg world)"/>
    <arg name="sdf" value="$(arg sdf)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="x" value="$(arg x)"/>
    <arg name="y" value="$(arg y)"/>
    <arg name="z" value="$(arg z)"/>
  </include>
</launch>
